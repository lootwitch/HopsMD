{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions HopsMD needs at runtime — folder picker and our own file/tree commands.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:event:default",
    "core:path:default",
    "core:app:default",
    "dialog:default",
    "dialog:allow-open",
    "opener:default",
    "opener:allow-open-path",
    "opener:allow-reveal-item-in-dir"
  ]
}
