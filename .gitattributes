# Normalize line endings to LF in the repo; checkouts get the platform-native
# style. Eliminates the "LF will be replaced by CRLF" warnings on Windows.
* text=auto eol=lf

# Source files — explicitly LF
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.cjs       text eol=lf
*.mjs       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.rs        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.md        text eol=lf
*.sh        text eol=lf

# Windows-only files
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Binary assets — never line-end-normalize
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.bmp       binary
*.ico       binary
*.icns      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.exe       binary
*.dll       binary
*.msi       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.7z        binary

# Lockfiles — keep on one line; mark as generated so GitHub collapses diffs
package-lock.json   linguist-generated=true
Cargo.lock          linguist-generated=true

# Generated/vendored content — exclude from language stats
dist/               linguist-generated=true
src-tauri/target/   linguist-vendored=true
src-tauri/gen/      linguist-generated=true
src-tauri/icons/    linguist-vendored=true
