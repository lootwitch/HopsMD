root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 100

[*.rs]
indent_size = 4
max_line_length = 100

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[{Makefile,*.mk}]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2
